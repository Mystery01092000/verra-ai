{
  "//": "Verra project settings for Claude Code / Cowork. Hooks enforce guardrails for a regulated-data product.",
  "permissions": {
    "allow": [
      "Read", "Edit", "Write", "Glob", "Grep",
      "Bash(npm run *)", "Bash(node *)", "Bash(python3 *)",
      "Bash(git status)", "Bash(git diff *)", "Bash(git add *)", "Bash(git commit *)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./**/*secret*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      { "hooks": [ { "type": "command", "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh\"" } ] }
    ],
    "UserPromptSubmit": [
      { "hooks": [ { "type": "command", "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/pii-guard.sh\"" } ] }
    ],
    "PreToolUse": [
      { "matcher": "Bash",        "hooks": [ { "type": "command", "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/guard-bash.sh\"" } ] },
      { "matcher": "Write|Edit",  "hooks": [ { "type": "command", "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/protect-paths.sh\"" } ] }
    ],
    "PostToolUse": [
      { "matcher": "Write|Edit",  "hooks": [
        { "type": "command", "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/validate-design.sh\"" },
        { "type": "command", "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/format-code.sh\"" }
      ] }
    ]
  }
}
