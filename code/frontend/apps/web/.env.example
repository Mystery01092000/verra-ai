# Verra web — environment variables.
# Copy to .env.local (git-ignored) and fill in what you need.
# The chat route (app/api/chat/route.ts) tries providers in order:
# AWS Bedrock → Anthropic API → Verra backend gateway.

# ── AWS Bedrock (Amazon Nova) ───────────────────────────────────────
# Option A: Bedrock API bearer token.
AWS_BEARER_TOKEN_BEDROCK=
# Option B: standard AWS credentials (both required together).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional; defaults to us-east-1.
AWS_REGION=us-east-1

# ── Anthropic API (fallback when Bedrock is unavailable) ────────────
ANTHROPIC_API_KEY=

# ── Verra backend gateway (last-resort provider) ────────────────────
# Start it with: cd code/backend && docker compose up -d
# Optional; defaults to http://localhost:8080.
NEXT_PUBLIC_GATEWAY_URL=http://localhost:8080

# ── Auth (NextAuth) ─────────────────────────────────────────────────
# REQUIRED in production; dev falls back to an insecure default with a warning.
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
